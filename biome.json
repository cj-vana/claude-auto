{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "warn",
				"useTemplate": "warn"
			},
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedFunctionParameters": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"files": {
		"includes": ["**/*.ts", "**/*.json", "!!**/dist/", "!!**/node_modules/", "!!**/.planning/"]
	}
}
