{
	"name": "@cjvana/claude-auto",
	"version": "0.2.0",
	"description": "Autonomous Claude Code cron jobs for continuous codebase improvement",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"bin": {
		"claude-auto": "./dist/claude-auto.js",
		"claude-auto-run": "./dist/claude-auto-run.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist/",
		".claude-plugin/",
		"skills/",
		"scripts/postinstall.mjs",
		"scripts/preuninstall.mjs",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsx watch src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"postinstall": "node scripts/postinstall.mjs",
		"preuninstall": "node scripts/preuninstall.mjs"
	},
	"keywords": [
		"claude",
		"claude-code",
		"autonomous",
		"cron",
		"ai"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cj-vana/claude-auto.git"
	},
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"better-sqlite3": "^12.8.0",
		"cron-parser": "^5.5.0",
		"cronstrue": "^3.14.0",
		"ink": "^6.8.0",
		"nanoid": "^5.1.7",
		"plist": "^3.1.0",
		"proper-lockfile": "^4.1.2",
		"react": "^19.2.4",
		"write-file-atomic": "^7.0.1",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.0",
		"@types/plist": "^3.0.5",
		"@types/proper-lockfile": "^4.1.4",
		"@types/react": "^19.2.14",
		"ink-testing-library": "^4.0.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
